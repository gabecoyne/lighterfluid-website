  "founder": [
    {"@type": "Person", "name": "Gabe Coyne", "jobTitle": "Founder", "email": "gabe@lighterfluid.co"},
    {"@type": "Person", "name": "Collin Duff", "jobTitle": "Co-Founder", "email": "collin@lighterfluid.co"}
  ],
  "foundingDate": "2024",
  "knowsAbout": [
    "AI consulting",
    "Direct-to-consumer ecommerce",
    "Conversion rate optimization",
    "Media buying",
    "Brand strategy",
    "Founder coaching"
