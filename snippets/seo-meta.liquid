{%- comment -%}
  Context-aware SEO + Open Graph + Twitter Card + JSON-LD.

  Renders the right metadata based on the current template / page handle.
  Called from layout/theme.liquid head — no parameters needed.

  When a new page is added: add a {% when 'handle' %} branch below.
{%- endcomment -%}

{%- assign domain = 'https://lighterfluid.co' -%}
{%- comment -%} og:image lives in theme assets so it's version-controlled. asset_url returns a protocol-relative URL (//cdn.shopify.com/...), force absolute https for OG/Twitter scrapers. {%- endcomment -%}
{%- assign og_image = 'og-image.jpg' | asset_url | prepend: 'https:' -%}

{%- liquid
  if template.name == 'index'
    assign page_handle = 'home'
  else
    assign page_handle = page.handle
  endif
-%}

{%- case page_handle -%}

  {%- when 'home' -%}
    {%- assign meta_title = 'Lighter Fluid — Operator-led AI consulting for consumer brands' -%}
    {%- assign meta_description = 'Lighter Fluid installs AI skills inside consumer brands in 90 days. Founded by operators behind Stix Golf ($100M+ lifetime sales) and Host Modern ($4.5M Year 1, 10%+ profit). Audit ($5K) · Install from $8K/mo · Operate $3K–$10K/mo · Founder coaching $4K/mo.' -%}
    {%- assign meta_path = '/' -%}

  {%- when 'implementation' -%}
    {%- assign meta_title = 'AI Implementation — Lighter Fluid · 90-day install · From $8K/mo' -%}
    {%- assign meta_description = 'A productized 90-day AI implementation for consumer brands on Shopify, Klaviyo, Triple Whale, Meta and Google Ads. Sixteen skill kits across five capability areas. Pricing from $8K/mo, $4K per additional kit. Standards layer included.' -%}
    {%- assign meta_path = '/pages/implementation' -%}

  {%- when 'coaching' -%}
    {%- assign meta_title = 'Founder Coaching — Lighter Fluid · $4K/mo · Weekly working sessions' -%}
    {%- assign meta_description = 'General startup coaching for consumer-brand founders. Weekly working sessions on strategy, fundraising, product, growth, hiring, and operations. AI fluency woven in. $4K per month, four slots only.' -%}
    {%- assign meta_path = '/pages/coaching' -%}

  {%- when 'work' -%}
    {%- assign meta_title = 'Work — Lighter Fluid · Stix Golf · Host Modern · Influence Mobile' -%}
    {%- assign meta_description = 'The case studies are the businesses we have built. Stix Golf — $100M+ lifetime sales, Series A & B. Host Modern — $4.5M Year 1, 10%+ profit margin. Influence Mobile — $200M+ lifetime revenue, 100M+ app installs.' -%}
    {%- assign meta_path = '/pages/work' -%}

  {%- when 'about' -%}
    {%- assign meta_title = 'About — Lighter Fluid · Two operators, five businesses' -%}
    {%- assign meta_description = 'Lighter Fluid is run by Gabe Coyne and Collin Duff. Five businesses between us, plus a venture studio role at Prota Ventures (innovation consulting for Exelon, ADP, Citi Bank).' -%}
    {%- assign meta_path = '/pages/about' -%}

  {%- when 'contact' -%}
    {%- assign meta_title = 'Book a call — Lighter Fluid' -%}
    {%- assign meta_description = 'Free 30-minute call. If we are a fit, you will know in twenty minutes. We read every form personally and reply within two business days.' -%}
    {%- assign meta_path = '/pages/contact' -%}

  {%- else -%}
    {%- assign meta_title = page.title | default: shop.name -%}
    {%- assign meta_description = page.content | strip_html | truncate: 160 | default: shop.description -%}
    {%- assign meta_path = canonical_url | remove: domain | default: '/' -%}

{%- endcase -%}

{%- assign canonical = domain | append: meta_path -%}

<title>{{ meta_title }}</title>
<meta name="description" content="{{ meta_description | escape }}">
<link rel="canonical" href="{{ canonical }}">

<meta property="og:type" content="website">
<meta property="og:title" content="{{ meta_title | escape }}">
<meta property="og:description" content="{{ meta_description | escape }}">
<meta property="og:url" content="{{ canonical }}">
<meta property="og:image" content="{{ og_image }}">
<meta property="og:site_name" content="Lighter Fluid">
<meta property="og:locale" content="en_US">

<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ meta_title | escape }}">
<meta name="twitter:description" content="{{ meta_description | escape }}">
<meta name="twitter:image" content="{{ og_image }}">

<meta name="author" content="Lighter Fluid">

{%- comment -%} Organization schema — emitted on every page {%- endcomment -%}
