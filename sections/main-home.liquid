{%- comment -%}
  main-home.liquid — body content for the Home page.
  Edit this file to update the page. No section editor in admin.
  SEO + JSON-LD live in snippets/seo-meta.liquid (context-aware via page.handle).
{%- endcomment -%}

<!-- ============ HERO ============ -->
  <header class="hero">
    <div class="container">
      <span class="eyebrow"><span class="dot"></span> Operator-led · AI consulting</span>
      <h1>
        We build the AI infrastructure your operators will <em>actually use.</em>
      </h1>
      <p class="lede">
        Three businesses. One operating playbook. We package the AI, automation, and systems we use to run our own companies — so yours can adopt them in weeks, not quarters.
      </p>
      <div class="actions">
        <a class="btn" href="{{ routes.root_url }}pages/contact">Book a call</a>
        <a class="btn ghost" href="{{ routes.root_url }}pages/implementation">See how we work</a>
      </div>
    </div>
  </header>

  <!-- ============ PROOF STATS ============ -->
  <section class="section sm">
    <div class="container">
      <div class="stats">
        <div class="stat">
          <div class="label">Stix Golf</div>
          <div class="val">$100M+<span class="small">Lifetime sales · $8M Year 1 · Series A &amp; B</span></div>
        </div>
        <div class="stat">
          <div class="label">Host Modern</div>
          <div class="val">$4.5M<span class="small">Year 1 · 10%+ profit margin</span></div>
        </div>
        <div class="stat">
          <div class="label">Influence Mobile</div>
          <div class="val">$200M+<span class="small">Lifetime revenue · #3 mobile ad network · 100M+ installs</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ CAPABILITY AREAS ============ -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="label">01 · What we install</span>
        <h2>Six capability areas.<br/><em>Twenty-plus skills.</em></h2>
      </div>

      <div class="row-list">
        <div class="row">
          <div class="num">AREA · 01</div>
          <div><h3>Brand</h3></div>
          <div class="body">UI kits. Brand guidelines. Voice rules. Audience cohorts. Copy-rules enforcement.</div>
          <div class="meta">Foundation</div>
        </div>
        <div class="row">
          <div class="num">AREA · 02</div>
          <div><h3>Marketing</h3></div>
          <div class="body">Media buying. Ad generation. Ad strategy. Social outreach. Email + SMS. Competitor monitoring.</div>
          <div class="meta">Acquisition + Retention</div>
        </div>
        <div class="row">
          <div class="num">AREA · 03</div>
          <div><h3>Ecom</h3></div>
          <div class="body">Website build. CRO program. Landing pages. A/B and MVT infrastructure.</div>
          <div class="meta">Conversion</div>
        </div>
        <div class="row">
          <div class="num">AREA · 04</div>
          <div><h3>Operations</h3></div>
          <div class="body">Financial modeling. Demand planning. FP&amp;A. Inventory management. Freight monitoring. Supplier sourcing.</div>
          <div class="meta">Backbone</div>
        </div>
        <div class="row">
          <div class="num">AREA · 05</div>
          <div><h3>Product</h3></div>
          <div class="body">Roadmap. Concept validation. Prototyping. Tech packs. Supplier collaboration.</div>
          <div class="meta">Pipeline</div>
        </div>
        <div class="row">
          <div class="num" style="color:var(--lf-ember);">AREA · 06</div>
          <div><h3 style="color:var(--lf-ember);font-style:italic;">Custom</h3></div>
          <div class="body">We built every skill above for our own businesses. We can build new ones for yours. Quote on the call.</div>
          <div class="meta">Built for you</div>
        </div>
      </div>

      <p style="margin-top:32px;"><a class="inline-link" href="{{ routes.root_url }}pages/implementation">See the full skill list →</a></p>
    </div>
  </section>

  <!-- ============ PULL QUOTE (charcoal) ============ -->
  <section class="section sm dark">
    <div class="container narrow">
      <p class="pullquote">
        Most AI consulting is a deck and a chatbot.<br/>The deck stays in a folder, the chatbot quietly stops getting used.<br/>What we install runs every day, gets logged, and gets better.
      </p>
    </div>
  </section>

  <!-- ============ HOW WE WORK ============ -->
  <section class="section rule">
    <div class="container">
      <div class="section-head">
        <span class="label">02 · How we work with you</span>
        <h2>Two ways in.<br/><em>Both designed to compound, not bill.</em></h2>
      </div>

      <div class="row-2col">
        <article class="card" style="padding:40px 36px;">
          <span class="num" style="font-family:var(--lf-mono);font-size:11px;letter-spacing:0.16em;text-transform:uppercase;color:var(--lf-mute);">Implementation</span>
          <h3 style="font-family:var(--lf-serif);font-weight:400;font-size:30px;line-height:1.1;letter-spacing:-0.015em;margin:8px 0 4px;">90 days. Done.</h3>
          <p style="font-family:var(--lf-serif);font-style:italic;font-size:17px;line-height:1.5;color:var(--lf-graphite);">
            We pick the skills that matter most for your business, install them end-to-end in 90 days, train your team, and leave the documentation to extend.
          </p>
          <div style="margin:24px 0 8px;padding:16px 0;border-top:1px solid var(--lf-rule);border-bottom:1px solid var(--lf-rule);font-family:var(--lf-serif);font-size:22px;font-weight:400;color:var(--lf-ink);letter-spacing:-0.01em;">
            <strong style="font-weight:500;color:var(--lf-ember);">From $10K/mo</strong> · 90 days · billed monthly
          </div>
          <p style="font-size:14px;line-height:1.6;color:var(--lf-graphite);margin-top:8px;">
            Base pack $30K total (90 days). Most engagements land at $30K–$60K depending on scope. Optional post-launch retainer at $5K–$10K/mo.
          </p>
          <p style="margin-top:18px;"><a class="inline-link" href="{{ routes.root_url }}pages/implementation">See implementation details →</a></p>
        </article>

        <article class="card" style="padding:40px 36px;">
          <span class="num" style="font-family:var(--lf-mono);font-size:11px;letter-spacing:0.16em;text-transform:uppercase;color:var(--lf-mute);">Coaching</span>
          <h3 style="font-family:var(--lf-serif);font-weight:400;font-size:30px;line-height:1.1;letter-spacing:-0.015em;margin:8px 0 4px;">Weekly working sessions.</h3>
          <p style="font-family:var(--lf-serif);font-style:italic;font-size:17px;line-height:1.5;color:var(--lf-graphite);">
            For consumer-brand founders who want senior operators in the room every week. Strategy, fundraising, product, growth — and AI fluency woven in.
          </p>
          <div style="margin:24px 0 8px;padding:16px 0;border-top:1px solid var(--lf-rule);border-bottom:1px solid var(--lf-rule);font-family:var(--lf-serif);font-size:22px;font-weight:400;color:var(--lf-ink);letter-spacing:-0.01em;">
            <strong style="font-weight:500;color:var(--lf-ember);">$4K/mo</strong> · weekly meetings · ongoing
          </div>
          <p style="font-size:14px;line-height:1.6;color:var(--lf-graphite);margin-top:8px;">
            One 60-minute session a week. Slack access between sessions. We accept four coaching clients at a time.
          </p>
          <p style="margin-top:18px;"><a class="inline-link" href="{{ routes.root_url }}pages/coaching">See coaching details →</a></p>
        </article>
      </div>
    </div>
  </section>

  <!-- ============ FOUNDERS ============ -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="label">03 · Who we are</span>
        <h2>Operators first.<br/><em>Consultants by accident.</em></h2>
      </div>

      <div class="founder-cards">
        <article class="founder-card">
          <header>
            <img class="avatar" src="{{ 'founder-gabe.jpg' | asset_url }}" alt="Gabe Coyne" width="56" height="56">
            <div class="ident">
              <h3>Gabe Coyne</h3>
              <p class="role">Founder · Visionary</p>
            </div>
          </header>
          <ul class="credit-list">
            <li><span class="num">$200M+</span><span class="line">Co-founded Influence Mobile — #3 mobile ad network in the world</span></li>
            <li><span class="num">$100M+</span><span class="line">Co-founded Stix Golf in 2020 — Series A &amp; B</span></li>
            <li><span class="num">$4.5M</span><span class="line">CEO of Host Modern — year one, 10%+ profit margin</span></li>
            <li><span class="num">10 yrs</span><span class="line">Ran a creative studio in Seattle before Influence Mobile</span></li>
            <li><span class="num">Partner</span><span class="line">Prota Ventures — innovation consulting for Exelon, ADP, Citi Bank</span></li>
          </ul>
          <a class="card-link" href="https://www.linkedin.com/in/gabecoyne" target="_blank" rel="noopener">LinkedIn →</a>
        </article>

        <article class="founder-card">
          <header>
            <img class="avatar" src="{{ 'founder-collin.jpg' | asset_url }}" alt="Collin Duff" width="56" height="56">
            <div class="ident">
              <h3>Collin Duff</h3>
              <p class="role">Co-Founder · Integrator</p>
            </div>
          </header>
          <ul class="credit-list">
            <li><span class="num">COO</span><span class="line">Host Modern through its launch</span></li>
            <li><span class="num">Head of Product</span><span class="line">Stix Golf — current</span></li>
            <li><span class="num">Co-founder</span><span class="line">Viator Coffee</span></li>
            <li><span class="num">Operator</span><span class="line">Product-and-ops counterweight to Gabe's growth-and-systems instinct</span></li>
          </ul>
          <a class="card-link" href="https://www.linkedin.com/in/collin-duff-1bba92144/" target="_blank" rel="noopener">LinkedIn →</a>
        </article>
      </div>
    </div>
  </section>

  <!-- ============ WALLS WE HIT ============ -->
  <section class="section sm">
    <div class="container">
      <blockquote class="wall-quote">
        <p>We&apos;re not strategists who studied ecommerce.<br/>We&apos;re the people who <em>hit the wall</em> — and built systems around it.</p>
      </blockquote>

      <ul class="wall-tags">
        <li>Inventory</li>
        <li>Attribution</li>
        <li>Creative fatigue</li>
        <li>Customer support</li>
        <li>Ops</li>
      </ul>

      <p class="wall-bridge">Lighter Fluid is the documentation layer for those systems. <a class="inline-link" href="{{ routes.root_url }}pages/about">Read more about us →</a></p>
    </div>
  </section>
  <!-- ============ BETWEEN US (charcoal) ============ -->
  <section class="section dark">
    <div class="container">
      <div class="section-head">
        <span class="label">04 · Between us</span>
        <h2>Two operators.<br/><em>What we&apos;ve put on the board.</em></h2>
      </div>

      <div class="big-stat-grid">
        <div class="big-stat">
          <div class="val">5</div>
          <div class="label">Businesses launched</div>
          <div class="desc">Stix, Host Modern, Influence Mobile, Viator Coffee, creative studio.</div>
        </div>
        <div class="big-stat">
          <div class="val">$300M+</div>
          <div class="label">Lifetime revenue</div>
          <div class="desc">Across all five businesses we have operated.</div>
        </div>
        <div class="big-stat">
          <div class="val">$50M+</div>
          <div class="label">Capital raised</div>
          <div class="desc">Across Series A, Series B, and earlier rounds.</div>
        </div>
        <div class="big-stat">
          <div class="val">100K+</div>
          <div class="label">Customers</div>
          <div class="desc">Hundreds of thousands across the brands.</div>
        </div>
        <div class="big-stat">
          <div class="val">100s</div>
          <div class="label">Employees hired</div>
          <div class="desc">Operators recruited, onboarded, managed.</div>
        </div>
        <div class="big-stat">
          <div class="val">100s</div>
          <div class="label">Products to market</div>
          <div class="desc">Concept through launch — digital and physical.</div>
        </div>
        <div class="big-stat">
          <div class="val">1,000s</div>
          <div class="label">SKUs managed</div>
          <div class="desc">Across product lines, seasons, channels.</div>
        </div>
        <div class="big-stat">
          <div class="val">Red Dot<br>+ Inc. 5000</div>
          <div class="label">Awards &amp; press</div>
          <div class="desc">Sports Illustrated, Entrepreneur, Forbes, Golf Magazine, MoMA, Mission.org.</div>
        </div>
      </div>
    </div>
  </section>


  <!-- ============ CTA ============ -->
  <section class="section">
    <div class="container">
      <div class="cta-block dark">
        <h2>Free 30-minute call.<br/><em>If we're a fit, you'll know in twenty.</em></h2>
        <div class="actions">
          <a class="btn ember" href="{{ routes.root_url }}pages/contact">Book a call</a>
          <a class="inline-link" href="{{ routes.root_url }}pages/implementation">Or see how we work →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ FOOTER ============ -->

