{%- comment -%}
  main-contact.liquid — body content for the Contact page.
  Edit this file to update the page. No section editor in admin.
  SEO + JSON-LD live in snippets/seo-meta.liquid (context-aware via page.handle).
{%- endcomment -%}

<header class="hero short">
    <div class="container">
      <span class="eyebrow"><span class="dot"></span> Contact · Free 30-minute call · Direct line</span>
      <h1>Tell us what you're working on.<br/><em>If we're a fit, you'll know in twenty minutes.</em></h1>
      <p class="lede">No discovery deck. No procurement form. Just a conversation. We read every form personally and reply within two business days.</p>
    </div>
  </header>

  <section class="section">
    <div class="container">
      <div class="row-2col asym">
        <div>
          <h2 style="font-family:var(--lf-serif);font-weight:350;font-size:32px;line-height:1.15;letter-spacing:-0.015em;color:var(--lf-ink);">Tell us about your business.</h2>
          <p style="margin-top:24px;font-size:16px;line-height:1.65;color:var(--lf-ink-soft);max-width:480px;">
            We read every form personally. Within two business days you'll get a reply from Gabe or Collin — either confirmation that we're a fit, or a candid note about why we're not (and a referral if we know someone better-suited).
          </p>

          <div class="byline" style="margin-top:20px;">
            <span class="avatar-pair">
              <img class="avatar sm" src="{{ 'founder-gabe.jpg' | asset_url }}" alt="Gabe Coyne" width="28" height="28">
              <img class="avatar sm" src="{{ 'founder-collin.jpg' | asset_url }}" alt="Collin Duff" width="28" height="28">
            </span>
            <span>Gabe &amp; Collin</span>
          </div>

          <div style="margin-top:48px;padding-top:32px;border-top:1px solid var(--lf-rule);">
            <span class="eyebrow"><span class="dot"></span> Or email directly</span>
            <p style="margin-top:18px;font-family:var(--lf-serif);font-size:18px;line-height:1.6;">
              <a class="inline-link" href="mailto:gabe@lighterfluid.co">gabe@lighterfluid.co</a><br />
              <a class="inline-link" href="mailto:collin@lighterfluid.co">collin@lighterfluid.co</a>
            </p>
          </div>

          <div style="margin-top:48px;padding-top:32px;border-top:1px solid var(--lf-rule);">
            <span class="eyebrow"><span class="dot"></span> Engagement minimums</span>
            <p style="margin-top:18px;font-size:14px;line-height:1.65;color:var(--lf-graphite);max-width:380px;">
              Implementations start at $10K/mo for 90 days. Coaching is $4K/mo, four slots. We don't run on hourly billing. We're consumer / DTC focused and won't take work in regulated industries (healthcare, financial services, manufacturing) unless you have a strong operator already inside.
            </p>
          </div>
        </div>

        <div>
          {%- comment -%}
            Native Shopify contact form. Submissions email the shop's contact
            address (Settings → General → Senders / Customer email).
            Custom fields (Company, Role, Revenue, Interest, Capability) are
            included in the email body labeled by their field name.
          {%- endcomment -%}
          {%- form 'contact', class: 'form' -%}
            {%- if form.posted_successfully? -%}
              <div style="padding:32px 28px;border:1px solid var(--lf-ember);background:var(--lf-ember-soft);">
                <span class="eyebrow" style="color:var(--lf-ember);"><span class="dot"></span> Sent</span>
                <h3 style="font-family:var(--lf-serif);font-weight:400;font-size:24px;line-height:1.2;letter-spacing:-0.01em;margin-top:12px;color:var(--lf-ink);">
                  Thanks — we got it.
                </h3>
                <p style="margin-top:12px;font-size:15px;line-height:1.6;color:var(--lf-ink-soft);">
                  Within two business days you'll hear back from Gabe or Collin directly. If we're a fit, we'll schedule a 30-minute call. If we're not, we'll tell you why and refer you on.
                </p>
              </div>
            {%- else -%}
              {%- if form.errors -%}
                <div style="padding:18px 22px;border:1px solid var(--lf-negative,#9c2c1c);background:#fdecea;margin-bottom:24px;color:var(--lf-negative,#9c2c1c);font-size:14px;line-height:1.55;">
                  <strong>Something needs fixing:</strong>
                  <ul style="margin:8px 0 0 18px;list-style:disc;">
                    {%- for field in form.errors -%}
                      <li>{{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.messages[field] }}</li>
                    {%- endfor -%}
                  </ul>
                </div>
              {%- endif -%}

              <div class="field">
                <label for="contact-name">Your name</label>
                <input id="contact-name" name="contact[name]" type="text" autocomplete="name" required />
              </div>

              <div class="field">
                <label for="contact-email">Email</label>
                <input id="contact-email" name="contact[email]" type="email" autocomplete="email" required />
              </div>

              <div class="field">
                <label for="contact-company">Company</label>
                <input id="contact-company" name="contact[Company]" type="text" required />
              </div>

              <div class="field">
                <label for="contact-role">Your role</label>
                <input id="contact-role" name="contact[Role]" type="text" placeholder="Founder / CEO / VP Growth / etc." />
              </div>

              <div class="field">
                <label for="contact-size">Annual revenue range</label>
                <select id="contact-size" name="contact[Revenue range]">
                  <option value="">Select range</option>
                  <option>Under $5M</option>
                  <option>$5M – $15M</option>
                  <option>$15M – $50M</option>
                  <option>$50M – $150M</option>
                  <option>$150M+</option>
                  <option>Pre-revenue / haven't launched</option>
                </select>
              </div>

              <div class="field">
                <label for="contact-interest">What you're interested in</label>
                <select id="contact-interest" name="contact[Interest]">
                  <option value="">Select</option>
                  <option>AI Install (90 days)</option>
                  <option>Founder Coaching ($4K/mo)</option>
                  <option>Not sure — let's talk</option>
                </select>
              </div>

              <div class="field">
                <label for="contact-capability">Capability area (if relevant)</label>
                <select id="contact-capability" name="contact[Capability area]">
                  <option value="">Select if known</option>
                  <option>Brand</option>
                  <option>Marketing</option>
                  <option>Ecom</option>
                  <option>Operations</option>
                  <option>Product</option>
                  <option>Custom</option>
                  <option>More than one</option>
                  <option>Not sure yet</option>
                </select>
              </div>

              <div class="field">
                <label for="contact-body">What's on your mind?</label>
                <textarea id="contact-body" name="contact[body]" placeholder="The 1-3 things you'd want us to look at if we were sitting across the table. Don't polish."></textarea>
              </div>

              <div class="submit-row">
                <button class="btn ember no-arrow" type="submit">Send →</button>
              </div>
            {%- endif -%}
          {%- endform -%}
        </div>
      </div>
    </div>
  </section>

  <section class="section sm rule">
    <div class="container narrow">
      <span class="eyebrow"><span class="dot"></span> What happens after you submit</span>
      <div class="prose" style="margin-top:24px;">
        <p>Within two business days you'll get a personal reply from Gabe or Collin. If we're a fit, we'll schedule a 30-minute video call. If we're not, we'll tell you why and refer you on. Either way, you'll get a real answer from a real person.</p>
        <p>If we move forward, you'll get a one-page proposal within a week of the call. For an implementation, we start within two weeks of countersignature. For coaching, we book your first session inside seven days.</p>
      </div>
    </div>
  </section>

{% schema %}
{
  "name": "Main · Contact",
  "settings": []
}
{% endschema %}
